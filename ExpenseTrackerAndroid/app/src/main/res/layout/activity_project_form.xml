<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <EditText android:id="@+id/etProjectCode" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Project ID/Code *" />
        <EditText android:id="@+id/etProjectName" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Project Name *" />
        <EditText android:id="@+id/etDescription" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Project Description *" />
        <EditText android:id="@+id/etStartDate" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Start Date (YYYY-MM-DD) *" />
        <EditText android:id="@+id/etEndDate" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="End Date (YYYY-MM-DD) *" />
        <EditText android:id="@+id/etOwner" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Project Manager/Owner *" />

        <Spinner
            android:id="@+id/spStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <EditText android:id="@+id/etBudget" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Project Budget *" android:inputType="numberDecimal" />
        <EditText android:id="@+id/etSpecialRequirements" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Special requirements (optional)" />
        <EditText android:id="@+id/etClientInfo" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Client/Department info (optional)" />
        <EditText android:id="@+id/etNotes" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Additional notes (optional)" />

        <Button
            android:id="@+id/btnSaveProject"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Project" />
    </LinearLayout>
</ScrollView>
